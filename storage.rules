rules_version = '2';

// RPelago — Firebase Storage.
//
// The only thing stored here is casino Slot-Fill manifests: one Archipelago
// player YAML per seat, owner-scoped. Everything else is denied. YAML is inert
// text (never executed on our side) — the concern is access scoping and storage
// hygiene, not code execution.
service firebase.storage {
  match /b/{bucket}/o {

    // casino/{seasonId}/{missionId}/{uid}.yaml — one object per seat, replaced on
    // re-submit. Only the owning player may read/write/delete their own file.
    // Admin review happens via the Firebase console / Admin SDK (both bypass
    // these rules); adminId lives in RTDB, which Storage rules cannot read, so
    // there is deliberately no admin clause here.
    match /casino/{seasonId}/{missionId}/{fileName} {
      allow read, delete: if request.auth != null
        && fileName == request.auth.uid + '.yaml';

      allow write: if request.auth != null
        && fileName == request.auth.uid + '.yaml'
        && request.resource.size < 64 * 1024
        && request.resource.contentType.matches('(text/.*|application/(x-)?yaml|application/octet-stream)');
    }

    // Default-deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
