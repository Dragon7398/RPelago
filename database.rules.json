{
  "rules": {
    "profiles": {
      "players": {
        "$uid": {
          ".read":  true,
          ".write": false
        }
      },
      "handleIndex": {
        ".read":  true,
        ".write": false
      }
    },

    "game": {
      ".read": true,
      ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",

      "tiles": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
        "$coord": {
          "adventurers": {
            "$advId": {
              ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || newData.child('owner').val() === auth.uid || data.child('owner').val() === auth.uid)",
              ".validate": "!newData.exists() || root.child('game/meta/adminId').val() === auth.uid || (newData.child('owner').val() === auth.uid && newData.child('advId').val() === $advId && newData.child('ownerName').val() === root.child('game/players').child(auth.uid).child('displayName').val() && root.child('game/players').child(auth.uid).child('adventurers').child($advId).exists() && (data.exists() || root.child('game/tiles').child($coord).child('state').val() !== 'inprogress' || root.child('game/tiles').child($coord).child('claimableSlots').exists()))",
              "statusNote": {
                ".validate": "!newData.exists() || (newData.hasChildren(['text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 280 && newData.child('timestamp').isNumber())"
              }
            }
          },
          "claimableSlots": {
            "$slotKey": {
              ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || (!newData.exists() && data.exists()))"
            }
          }
        }
      },

      "players": {
        "$playerId": {
          ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
          ".validate": "root.child('game/meta/adminId').val() === auth.uid || (newData.child('xp').val() === data.child('xp').val() && newData.child('gold').val() === data.child('gold').val())",

          "adventurers": {
            "$advId": {
              ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)"
            }
          },

          "nameColor": {
            ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)"
          },

          "feats": {
            "$slot": {
              ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)",
              ".validate": "newData.isString() && newData.val().length > 0 && (!data.exists() || root.child('game/meta/adminId').val() === auth.uid)"
            }
          },

          "xp": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "gold": {
            ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "inventory": {
            "$itemId": {
              ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          },

          "warnings": {
            "$warnKey": {
              ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
            }
          }
        }
      },

      "orbState": {
        "$orbId": {
          ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
        }
      },

      "shops": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "orbConfig": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "meta": {
        ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || !root.child('game/meta/initialized').exists())"
      },

      "missions": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
        "$missionId": {
          "claimableSlots": {
            "$slotKey": {
              // Any authenticated player may delete (claim) an existing slot.
              // Mirrors the tile claimableSlots pattern.
              ".write": "auth != null && !newData.exists() && data.exists()"
            }
          },

          "participants": {
            "$participantId": {
              // Casino game state written exclusively by Cloud Functions (admin SDK bypasses rules).
              // Client-side protections below are an extra safety net.

              "deck": {
                // The server-held draw deck must never be exposed to any browser client —
                // seeing the remaining cards would let a player engineer their hand.
                // Cloud Functions read/write this via the admin SDK (bypasses all rules).
                ".read":  false,
                ".write": false
              },

              "hand": {
                // The player's current hand is readable only by that player's own session
                // so the table UI can recover after a page reload.  Other players (and
                // the admin client) cannot read an active hand in progress.
                // Writes go exclusively through Cloud Functions.
                ".read":  "auth != null && auth.uid === $participantId",
                ".write": false
              }
            }
          }
        }
      },

      "missionsHistory": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "notifications": {
        "$uid": {
          // Client deletes its own entries on receipt.
          // Read is already granted by parent game/.read: true.
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "kmkEvents": {
      // Public read — the player trial board is viewable by anyone.
      ".read": true,

      "$listId": {
        // Admin may create, modify, or delete any list.
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",

        "areas": {
          "$areaId": {
            "tasks": {
              "$taskId": {
                // Admin: full write.
                // Player: may only touch their own claimed task that is not yet Complete.
                //   Mark Done  → Pending → Verifying    (status only)
                //   Resume     → Verifying → Pending    (status only)
                //   Abandon    → Pending|Verifying → Incomplete (clears player fields)
                // Claim (Incomplete → Pending) goes through kmkClaimTrial Cloud Function (admin SDK).
                ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || (data.child('playerId').val() === auth.uid && data.child('status').val() !== 'Complete'))",
                ".validate": "root.child('game/meta/adminId').val() === auth.uid || (newData.child('trial').val() === data.child('trial').val() && newData.child('desc').val() === data.child('desc').val() && newData.child('order').val() === data.child('order').val() && ((newData.child('status').val() === 'Incomplete' && newData.child('playerId').val() === null && newData.child('playerName').val() === null && newData.child('claimedAt').val() === null) || ((newData.child('status').val() === 'Pending' || newData.child('status').val() === 'Verifying') && newData.child('playerId').val() === auth.uid)))"
              }
            }
          }
        }
      }
    }
  }
}
