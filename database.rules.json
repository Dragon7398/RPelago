{
  "rules": {
    "game": {
      ".read": true,
      ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",

      "tiles": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
        "$coord": {
          "adventurers": {
            "$advId": {
              ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || newData.child('owner').val() === auth.uid || data.child('owner').val() === auth.uid)",
              ".validate": "!newData.exists() || root.child('game/meta/adminId').val() === auth.uid || (newData.child('owner').val() === auth.uid && newData.child('advId').val() === $advId && newData.child('ownerName').val() === root.child('game/players').child(auth.uid).child('displayName').val() && root.child('game/players').child(auth.uid).child('adventurers').child($advId).exists())"
            }
          }
        }
      },

      "players": {
        "$playerId": {
          ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || (!data.exists() && auth.uid === $playerId))",
          ".validate": "!data.exists() || root.child('game/meta/adminId').val() === auth.uid || (newData.child('xp').val() === 0 && newData.child('gold').val() === 0)",

          "adventurers": {
            "$advId": {
              ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)"
            }
          },

          "nameColor": {
            ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)"
          },

          "feats": {
            "$slot": {
              ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)",
              ".validate": "newData.isString() && newData.val().length > 0"
            }
          },

          "xp": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "gold": {
            ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "inventory": {
            "$itemId": {
              ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          }
        }
      },

      "orbState": {
        "$orbId": {
          ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
        }
      },

      "shops": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "orbConfig": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "meta": {
        ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || !root.child('game/meta/initialized').exists())"
      }
    }
  }
}
