{
  "rules": {
    "profiles": {
      "players": {
        "$uid": {
          ".read":  true,
          ".write": false
        }
      },
      "handleIndex": {
        ".read":  true,
        ".write": false
      }
    },

    "game": {
      ".read": true,
      ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",

      "tiles": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
        "$coord": {
          "adventurers": {
            "$advId": {
              ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || newData.child('owner').val() === auth.uid || data.child('owner').val() === auth.uid)",
              ".validate": "!newData.exists() || root.child('game/meta/adminId').val() === auth.uid || (newData.child('owner').val() === auth.uid && newData.child('advId').val() === $advId && newData.child('ownerName').val() === root.child('game/players').child(auth.uid).child('displayName').val() && root.child('game/players').child(auth.uid).child('adventurers').child($advId).exists() && (data.exists() || root.child('game/tiles').child($coord).child('state').val() !== 'inprogress' || root.child('game/tiles').child($coord).child('claimableSlots').exists()))",
              "statusNote": {
                ".validate": "!newData.exists() || (newData.hasChildren(['text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 280 && newData.child('timestamp').isNumber())"
              }
            }
          },
          "claimableSlots": {
            "$slotKey": {
              ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || (!newData.exists() && data.exists()))"
            }
          }
        }
      },

      "players": {
        "$playerId": {
          ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
          ".validate": "root.child('game/meta/adminId').val() === auth.uid || (newData.child('xp').val() === data.child('xp').val() && newData.child('gold').val() === data.child('gold').val())",

          "adventurers": {
            "$advId": {
              ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)"
            }
          },

          "nameColor": {
            ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)"
          },

          "feats": {
            "$slot": {
              ".write": "auth != null && (auth.uid === $playerId || root.child('game/meta/adminId').val() === auth.uid)",
              ".validate": "newData.isString() && newData.val().length > 0 && (!data.exists() || root.child('game/meta/adminId').val() === auth.uid)"
            }
          },

          "xp": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "gold": {
            ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "inventory": {
            "$itemId": {
              ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          },

          "warnings": {
            "$warnKey": {
              ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
            }
          }
        }
      },

      "orbState": {
        "$orbId": {
          ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
        }
      },

      "shops": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "orbConfig": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "meta": {
        ".write": "auth != null && (root.child('game/meta/adminId').val() === auth.uid || !root.child('game/meta/initialized').exists())"
      },

      "missions": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid",
        "$missionId": {
          "claimableSlots": {
            "$slotKey": {
              // Any authenticated player may delete (claim) an existing slot.
              // Mirrors the tile claimableSlots pattern.
              ".write": "auth != null && !newData.exists() && data.exists()"
            }
          }
        }
      },

      "missionsHistory": {
        ".write": "auth != null && root.child('game/meta/adminId').val() === auth.uid"
      },

      "notifications": {
        "$uid": {
          // Client deletes its own entries on receipt.
          // Read is already granted by parent game/.read: true.
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }
  }
}
